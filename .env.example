# Copy to .env and fill in. .env is gitignored.

# ---------------------------------------------------------------------- #
# Direct providers (used when FACTORY_PROVIDER=direct or
# routes.yaml's ``default_provider: direct``).
# ---------------------------------------------------------------------- #

# Cheap, default model provider for Dev / Test-Implementer / Tech-Writer / SM
DEEPSEEK_API_KEY=

# OpenRouter — OPTIONAL. The plumbing supports ``openrouter/<vendor>/<model>``
# ids (one key, 100+ open models) but no production route uses it today —
# operator decision 2026-07-16: Azure-only. Routes pointing at a provider
# whose key is missing degrade to the block fallback automatically.
OPENROUTER_API_KEY=

# Legacy — Anthropic models are no longer routed (operator constraint
# 2026-07-15: factory must be independent of Anthropic models/limits).
ANTHROPIC_API_KEY=

# Optional fallback / OpenAI-compat
OPENAI_API_KEY=

# Optional: override LiteLLM base_urls
# DEEPSEEK_BASE_URL=
# ANTHROPIC_BASE_URL=

# ---------------------------------------------------------------------- #
# Azure — TWO surfaces, pick the one your endpoint serves.
# Both default to enabled-when-set; the factory routes by model prefix in
# routes.yaml (azure_ai/<deployment> → Foundry; azure/<deployment> → OpenAI).
# ---------------------------------------------------------------------- #

# (A) Azure AI Foundry — services.ai.azure.com/models-style endpoints.
# Model ids in routes.yaml use the ``azure_ai/`` prefix.
# The factory remaps AZURE_FOUNDRY_* → AZURE_AI_API_* at startup so LiteLLM
# picks them up. You can set either set of names; the factory accepts both.
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_API_VERSION=

# Equivalent LiteLLM-named env vars for the Foundry surface (auto-populated
# from AZURE_FOUNDRY_* above unless explicitly set).
# AZURE_AI_API_BASE=
# AZURE_AI_API_KEY=
# AZURE_AI_API_VERSION=

# (B) Azure OpenAI / Cognitive Services — cognitiveservices.azure.com endpoints.
# Model ids in routes.yaml use the plain ``azure/`` prefix.
# AZURE_ENDPOINT is the operator-friendly name; the factory copies it into
# AZURE_API_BASE (the LiteLLM-standard name) at startup. AZURE_API_KEY and
# AZURE_API_VERSION already match LiteLLM's expected names — no remap.
AZURE_ENDPOINT=
AZURE_API_KEY=
AZURE_API_VERSION=

# Equivalent if you'd rather set LiteLLM-standard names directly:
# AZURE_API_BASE=

# Runtime provider override — flips routes.yaml's default without editing the
# file. Accepts "azure" or "direct".
# FACTORY_PROVIDER=azure
