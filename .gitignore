__pycache__/
*.pyc
*.pyo
.venv/
.env
.env.local
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/
*.egg-info/
state/*.db
state/*.db-journal
state/dry_run_scratch/
# Per-story event logs (JSONL, append-only, grow with chain activity).
# Surface via ``factory why`` / ``factory trace``; recreated on demand.
state/logs/
# Factory-improver proposal JSONs. Each ``factory improve`` run writes
# one; surfaced via the pinned GH issue and the L2 apply pass — durable
# state lives in the PRs that result, not here.
state/improvements/
# Event-trigger debounce / daily-cap history for the factory_improver
# (one ISO timestamp per fire, pruned to 24h). Pure runtime bookkeeping.
state/.improver_run_history.json
# Per-story git worktrees created by factory.chain.worktree. Each is a
# linked working dir under state/worktrees/<app>-<id>-<slug>/; sharing
# .git with the source app repo, NOT this one.
state/worktrees/
# FMS Phase-1 structured event streams (append-only NDJSON). Runtime-only;
# read via ``factory manager signals dump``. Do NOT commit .ndjson files.
state/events/
# FMS runtime telemetry — concern documents (L2) and diagnosis proposals
# (L3). Append-only runtime artifacts; the durable record is the PRs/issues
# they produce. Read via ``factory manager ...`` CLI, never from git.
state/concerns/
state/manager_proposals/
# Post-merge context-refresh scratch worktrees.
state/context-refresh/
# Halt/apply audit trails — runtime bookkeeping mutated by every
# halt/resume/apply cycle; ``factory resume`` archives into them.
state/.halt_history.json
state/.manager_apply_history.json
state/.improver_backoff.json
state/*.log

# coverage.py data file (never commit)
.coverage
